<Window x:Class="Flink.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flink"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        IsHitTestVisible="False"
        Focusable="False">

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="BgColor">#E6111318</Color>
        <Color x:Key="BorderColor">#33FFFFFF</Color>
        <Color x:Key="KeyColor">#FF5CB8FF</Color>
        <Color x:Key="KeyColorDim">#FF3A7DAF</Color>
        <Color x:Key="TextPrimary">#FFFFFFFF</Color>
        <Color x:Key="TextSecondary">#99FFFFFF</Color>
        <Color x:Key="AccentBar">#FF5CB8FF</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="KeyBrush" Color="{StaticResource KeyColor}"/>
        <SolidColorBrush x:Key="KeyBrushDim" Color="{StaticResource KeyColorDim}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentBarBrush" Color="{StaticResource AccentBar}"/>

        <!-- Shared item template for window list columns -->
        <DataTemplate x:Key="WindowItemTemplate">
            <Border x:Name="ItemBorder"
                    CornerRadius="8"
                    Padding="12,9,16,9"
                    Margin="0,2,0,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Key badge -->
                    <Border Grid.Column="0"
                            Background="#1A5CB8FF"
                            BorderBrush="#335CB8FF"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="7,3,7,3"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            MinWidth="32">
                        <TextBlock Text="{Binding Binding}"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource KeyBrush}"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- App icon -->
                    <Image Grid.Column="1"
                           Source="{Binding Icon}"
                           Width="18" Height="18"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- App name + window title -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CleanTitle}"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer drop shadow -->
    <Border Margin="16">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <!-- Main panel -->
        <Border x:Name="MainPanelBorder"
                Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="0"
                MinWidth="380"
                MaxWidth="560">

            <StackPanel>

                <!-- Header -->
                <Border Padding="20,14,20,12"
                        BorderBrush="{StaticResource BorderBrush2}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="6" Height="6" CornerRadius="3"
                                Background="{StaticResource AccentBarBrush}"
                                VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="flink"
                                   FontFamily="Segoe UI Variable, Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBarBrush}"
                                   VerticalAlignment="Center"
                                   />
                    </StackPanel>
                </Border>

                <!-- Window list (dual-column layout) -->
                <Grid x:Name="WindowListGrid" Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition x:Name="RightColumnDef" Width="0"/>
                    </Grid.ColumnDefinitions>

                    <ItemsControl x:Name="WindowListLeft" Grid.Column="0"
                                  ItemTemplate="{StaticResource WindowItemTemplate}"/>
                    <ItemsControl x:Name="WindowListRight" Grid.Column="1"
                                  ItemTemplate="{StaticResource WindowItemTemplate}"
                                  Margin="4,0,0,0"
                                  Visibility="Collapsed"/>
                </Grid>

                <!-- Footer hint -->
                <Border Padding="20,8,20,12"
                        BorderBrush="{StaticResource BorderBrush2}"
                        BorderThickness="0,1,0,0">
                    <TextBlock FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center">
                        <Run Text="type key to switch"/>
                        <Run Text=" · " Foreground="#445CB8FF"/>
                        <Run Text="esc to dismiss"/>
                    </TextBlock>
                </Border>

            </StackPanel>
        </Border>
    </Border>
</Window>
